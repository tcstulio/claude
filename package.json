{
  "name": "tulipa-api",
  "version": "0.4.0",
  "description": "Proxy API REST para o gateway Tulipa MCP",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test:manual": "./test/manual.sh"
  },
  "dependencies": {
    "express": "^4.21.0",
    "sql.js": "^1.14.1",
    "undici": "^7.24.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
