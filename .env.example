# Meta (Facebook) Marketing API Credentials
# Copie este arquivo para .env e preencha com suas credenciais reais:
#   cp .env.example .env

# App ID do seu aplicativo Meta (developers.facebook.com)
META_APP_ID=your_app_id_here

# App Secret do seu aplicativo Meta
META_APP_SECRET=your_app_secret_here

# Access Token com permissões ads_management e ads_read
# Recomendado: usar System User Token para tokens de longa duração
META_ACCESS_TOKEN=your_access_token_here
